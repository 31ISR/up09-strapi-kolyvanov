{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "Description": {
      "type": "string",
      "required": true
    },
    "duration": {
      "type": "integer",
      "required": true
    },
    "complexity": {
      "type": "enumeration",
      "required": true,
      "default": "easy",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "lessons": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::lesson.lesson",
      "mappedBy": "course"
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "firstName": {
      "type": "string",
      "required": true
    },
    "lastName": {
      "type": "string",
      "required": true
    },
    "enrollmentDate": {
      "type": "date"
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "group": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::group.group",
      "inversedBy": "students"
    },
    "enrollmentStatus": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Graduated",
        "Studying"
      ]
    }
  }
}
